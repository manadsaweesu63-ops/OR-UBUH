{
  "entities": {
    "Doctor": {
      "title": "Doctor",
      "description": "A doctor who performs surgeries",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the doctor"
        },
        "colorConfig": {
          "type": "object",
          "properties": {
            "bg": { "type": "string" },
            "text": { "type": "string" },
            "border": { "type": "string" },
            "bar": { "type": "string" },
            "shadow": { "type": "string" }
          }
        }
      },
      "required": ["name"]
    },
    "Surgery": {
      "title": "Surgery",
      "description": "A scheduled surgery",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "room": { "type": "string" },
        "doctor": { "type": "string" },
        "patientName": { "type": "string" },
        "patientHN": { "type": "string" },
        "patientAge": { "type": "string" },
        "procedure": { "type": "string" },
        "surgeryType": { "type": "string", "enum": ["Minor", "Major"] },
        "department": { "type": "string" },
        "status": { "type": "string", "enum": ["preparing", "surgery", "recovery", "completed", "canceled"] }
      },
      "required": ["date", "time", "room", "doctor", "patientName", "patientHN", "procedure", "surgeryType", "department"]
    }
  },
  "firestore": {
    "/doctors/{doctorId}": {
      "schema": "Doctor",
      "description": "List of doctors"
    },
    "/surgeries/{surgeryId}": {
      "schema": "Surgery",
      "description": "Scheduled surgeries"
    }
  }
}
